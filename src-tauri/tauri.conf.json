{
  "$schema": "https://raw.githubusercontent.com/nicklasoverworlds/tauri/dev/packages/api/schema.json",
  "productName": "悦音",
  "version": "0.1.0",
  "identifier": "com.yueyin.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "悦音",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
